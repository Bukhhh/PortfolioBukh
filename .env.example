# ============================================
# PORTFOLIO ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# NEVER commit your actual .env file to GitHub!
# ============================================

# Database — PostgreSQL connection string (get a free one at https://neon.tech)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"


# Session secret - generate a strong random string (minimum 32 chars)
# Example: openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret-string-minimum-32-chars"

# Admin default credentials (used only on first run if no admin exists)
# Change this immediately after first login!
ADMIN_DEFAULT_PASSWORD="change-me-immediately"

# Groq API key for the Robo chatbot (get one free at https://console.groq.com)
GROQ_API_KEY="your-groq-api-key-here"

